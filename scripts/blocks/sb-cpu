#!/bin/sh
# gruvbox cpu block — yellow icon, fg text. Average usage across all cores.

# Snapshot per-core busy/idle jiffies (all fields, so irq/iowait/steal count).
snap() {
	awk '/^cpu[0-9]/ {
		t = 0
		for (i = 2; i <= NF; i++) t += $i
		printf "%s %d %d\n", $1, t, $5 + $6   # core, total, idle+iowait
	}' /proc/stat
}

first=$(snap)
sleep 0.3
second=$(snap)

usage=$(printf '%s\n---\n%s\n' "$first" "$second" | awk '
	/^---/ { phase = 1; next }
	phase == 0 { t0[$1] = $2; i0[$1] = $3; next }
	{
		dt = $2 - t0[$1]
		di = $3 - i0[$1]
		if (dt > 0) { sum += 100 * (dt - di) / dt; n++ }
	}
	END { if (n > 0) printf "%d", sum / n; else print 0 }
')

# Leading padding separates this (leftmost) block from the window title.
printf "  ^c#fabd2f^󰘚 ^c#ebdbb2^%d%%^d^\n" "$usage"
